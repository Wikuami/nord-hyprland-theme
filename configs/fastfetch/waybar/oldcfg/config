{
    "layer": "top",
    "position": "top",
    "mod": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 36,
    "margin-right": 5,
    "margin-left": 5, 

    "modules-left": [
        "hyprland/workspaces",
    ],

    "modules-center": [
        "clock",
    ],

    "modules-right": [
        "tray",
        "battery",
        "pulseaudio",
        "pulseaudio#microphone",
        "cpu",
        "memory",
        "custom/updates",
        "network",
        "custom/power"
    ],
    "custom/power": {
        "format": "οÄë",
        "on-click": "wlogout",
        "tooltip": false
    },

    "hyprland/workspaces": {
        "on-click": "activate",
        "disable-scroll": true,
        "all-outputs": true,
        "show-special": true,
        "persistent-workspaces": {
            "*": [ 1, 2, 3, 4 ],
        },
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 25,
        "all-outputs": true,
        "tooltip-format": "{name}: {title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": [
            "rofi"
         ]
    },

    "tray": {
        "icon-size": 15,
        "spacing": 15
    },

    "cpu": {
        "interval": 10,
        "format": "ο΄¦",
        "max-length": 10,
        "format-alt-click": "click-right",
        "format-alt": "ο΄¦ {usage}%",
    },

    "memory": {
        "interval": 30,
        "format": "οÉâ",
        "format-alt-click": "click-right",
        "format-alt": "οÉâ {}%",
        "max-length": 10,
        "tooltip": true,
        "tooltip-format": "Memory - {used:0.1f}GB used",
    },

    "temperature": {
        "thermal-zone": 1,
        "format": "ο΄â",
        "format-alt-click": "click-right",
        "format-alt": "ο΄â {temperatureC}¬ΑC",
        "critical-threshold": 70,
        "format-critical": "ο΄΅ {temperatureC}¬ΑC",
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon}",
        "format-charging": "ο½ß {capacity}%",
        "format-plugged": "ο΅Π {capacity}%",
        "format-alt-click": "click-right",
        "format-alt": "{icon} {capacity}%",
        "states": {
            "warning": 20,
            "critical": 10
        },
        "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"]
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "οëΠ",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%-",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "οÄΞ",
            "hands-free": "οÄΞ",
            "headset": "οÄΞ",
            "phone": "ο²ï",
            "portable": "ο²ï",
            "car": "οÜΙ",
            "default": ["οÄΠ", "οÄß", "οÄ®"]
        },
        "tooltip": true,
        "tooltip-format": "{icon} at {volume}%"
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "ο³Α",
        "format-source-muted": "ο³±",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
        "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 5%+",
        "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 5%-",
        "scroll-step": 5,
        "tooltip": true,
        "tooltip-format": "ο³Α at {volume}%"
    },

    "custom/weather": {
        //shows the current weather and forecast
        "tooltip" : true,
        "format" : "{}",
        "interval" : 3600,
        "exec" : "~/.config/waybar/scripts/wttr.py",
        "return-type" : "json"
    },

    "custom/updates": {
        "format": "{}",
        "exec": "~/.config/waybar/scripts/update-sys",
        "on-click": "~/.config/waybar/scripts/update-sys update",
        "interval": 3600,
        "tooltip": true,
        "signal": 8,
        "return-type" : "json"
    },

    "network": {
        "format": "{ifname}",
        "format-wifi": "ο΅Ϊ ",
        "format-ethernet": "οû• ",
        "format-disconnected": "ο³ß ", //An empty format will hide the module.
        "tooltip-format": "οû• {ifname} via {gwaddr}",
        "tooltip-format-wifi": "ο΅Ϊ {essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "οÉ¹ {ifname} {ipaddr}/{cidr}",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50
    },

    "clock": {
          "format": "{:%H:%M}",
          "format-alt": "{:%a, %d %b %Y %H:%M}",
          "tooltip-format": "{:%A, %d %B %Y %H:%M:%S %Z}",
          "interval": 1,
          "timezone": "Europe/Kyiv",
          "on-click": "\"$(date '+%A, %d %B %Y %H:%M:%S' -d 'TZ=Europe/Kyiv')\""
    },

    "custom/khorshididate": { 
        "tooltip" : true,
        "format": "ο¹≥ {}",
        "format-alt": "ο¹≥ {alt}",
        "format-alt-click": "click-right",
        "interval": 3600,
        "exec": "~/.config/waybar/scripts/khorshidi-date",
        "return-type" : "json"
    },

   "hyprland/language": {
        "format": "{}",
        "on-click": "hyprctl switchxkblayout at-translated-set-2-keyboard next",
        "format-en": "EN",
        "format-fa": "FA"
   },

}
